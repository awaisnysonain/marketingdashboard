# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
SESSION_SECRET=change_this_to_a_random_64_char_string
# Cron is enabled by default only when NODE_ENV=production. Set explicitly on
# the one server that should run ETL jobs; keep false/blank on local dev boxes.
# ENABLE_CRON=true
# RUN_BOOT_LIVE_SYNC=false
# LIVE_SNAPSHOT_TIMEOUT_MS=1500000

# Auth: local dev skips ERP sign-in when NODE_ENV !== production.
# ERP_AUTH_BYPASS=true   force bypass in any environment
# ERP_AUTH_BYPASS=false  force real auth locally
ERP_VERIFY_URL=https://erp.nysonik.com/api/dashboard-token-verify.php
ERP_FRAME_ANCESTOR=https://erp.nysonik.com
ADMIN_EMAIL=admin@example.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=nobl_dashboard
DB_USER=your_db_user
DB_PASS=your_db_password
DB_SSL=false

# ── Triple Whale SQL API ──────────────────────────────────────────────────────
TW_SQL_URL=https://api.triplewhale.com/orcabase/api/sql
NOBL_TW_SHOP_ID=
NOBL_TW_API_KEY=
# NOBL EU ad-spend TW workspace (separate key; merges EU spend into NOBL brand totals)
NOBL_EU_TW_SHOP_ID=afmjag-r2.myshopify.com
NOBL_EU_TW_API_KEY=
FLO_TW_SHOP_ID=
FLO_TW_API_KEY=
FLO_EU_TW_SHOP_ID=
FLO_EU_TW_API_KEY=
TW_SQL_GAP_MS=1500

# ── Shopify Admin ─────────────────────────────────────────────────────────────
NOBL_SHOPIFY_SHOP=nobltravel.myshopify.com
NOBL_SHOPIFY_TOKEN=
FLO_SHOPIFY_SHOP=pilatesflo.myshopify.com
FLO_SHOPIFY_TOKEN=
FLO_EU_SHOPIFY_SHOP=
FLO_EU_SHOPIFY_TOKEN=
SHOP_TIMEZONE=America/New_York

# ── Appstle subscriptions ─────────────────────────────────────────────────────
APPSTLE_API_KEY=
APPSTLE_SHOP=nobltravel.myshopify.com
APPSTLE_BASE_URL=https://subscription-admin.appstle.com
FLO_APPSTLE_API_KEY=
FLO_APPSTLE_BASE_URL=https://subscription-admin.appstle.com
# FLO_APPSTLE_SYNC_BILLING_ATTEMPTS=true   expensive; off by default in cron

# ── Klaviyo ───────────────────────────────────────────────────────────────────
NOBL_KLAVIYO_API_KEY=
FLO_KLAVIYO_API_KEY=

# ── Meta Marketing API (per-brand ad spend) ───────────────────────────────────
# Each brand syncs from its own ad account/token so NOBL and FLO are both
# pulled accurately every day. Account id may be given with or without "act_".
NOBL_META_AD_ACCOUNT_ID=act_418992556365481
NOBL_META_ACCESS_TOKEN=
FLO_META_AD_ACCOUNT_ID=act_2134627150202827
FLO_META_ACCESS_TOKEN=
# Optional Graph API version (default v20.0); per-brand override: <BRAND>_META_API_VERSION
META_API_VERSION=v20.0
# Legacy single-account vars (still honored for NOBL if the per-brand ones are unset):
# META_AD_ACCOUNT_ID=act_418992556365481
# META_ADS_READ_TOKEN=

# ── Performance dashboard import (ETL only — not read at runtime) ─────────────
PERFORMANCE_DASHBOARD_SHEET_ID=1qPQTdmhx4yudt1h3qlqDpWAIyiBFVII1R6XTB6pfuh4
PERFORMANCE_DASHBOARD_GID=1601841795

# ── Google Sheets (optional — AI builder / ETL import sources) ───────────────
GOOGLE_API_KEY=
# NOBL plan calendar source — share workbook "Anyone with link can view" for CSV ETL
NOBL_FORECAST_SOURCE_SPREADSHEET_ID=1EaXjXyKcNE8Zbrrzy9niC1NFWDGiZNqhD4_Ip-dGjsI
FORECAST_PLAN_SUMMARY_GID=579680663
FORECAST_PLAN_SCENARIO_COMPARISON_GID=479926873
FORECAST_PLAN_SALES_CALENDAR_GID=1952401752
# ETL imports daily plan from these + Drops tabs:
FORECAST_PLAN_MAY_GID=1492391746
FORECAST_PLAN_JUN_GID=602524885
FORECAST_PLAN_JUL_GID=1385787391
FORECAST_PLAN_AUG_GID=1418412432
FORECAST_PLAN_SEP_GID=171716531
FORECAST_PLAN_OCT_GID=603693629
FORECAST_PLAN_NOV_GID=1889206458
FORECAST_PLAN_DEC_GID=1251767310
# Legacy workbook (deprecated for computed forecast import)
FORECAST_SHEET_ID=1XaMLQ_tqJYC7kOPm2Av4-CtZaX5Q1LBb6XYqBrSuIP4
FORECAST_AIR_DAILY_GID=1219449413
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=

# ── OpenAI (optional — AI assistant + dashboard builder) ──────────────────────
OPENAI_API_KEY=

# ── Caching ───────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
RESPONSE_CACHE_MAX=150

# ── Ops metrics ETL (KPI Pulse Ops rows) ─────────────────────────────────────
# Reads from the ERP Postgres (erp_maindb) — same DB SERVER as DB_HOST above,
# different database. The user (nysonianREAD) must be read-only at the DB level.
# UPS tracking token is fetched live from public.third_party_tokens (token_name='ups').
ERP_DB_HOST=54.172.115.118
ERP_DB_PORT=5432
ERP_DB_NAME=erp_maindb
ERP_DB_USER=nysonianREAD
ERP_DB_PASSWORD=
ERP_DB_SSL=false
# Optional override (default 100); UPS rate-limits aggressive concurrency.
# UPS_TRACKING_CONCURRENCY=100

# ── CS tickets ETL (KPI Pulse CS rows) ───────────────────────────────────────
# Two SSH tunnels must be active on whichever host runs this ETL:
#   ssh -N -L 27018:127.0.0.1:27017 <user>@<crmdb-host>   → NOBL crmdb
#   ssh -N -L 27019:127.0.0.1:27017 <user>@<flodb-host>   → FLO flodb
# Defaults inside server/etl/syncCsTickets.js match the reference script; override
# here if your URIs differ.
CS_NOBL_MONGO_URI=mongodb://<readonly-user>:<password>@127.0.0.1:27018/crmdb?authSource=crmdb
CS_FLO_MONGO_URI=mongodb://<readonly-user>:<password>@127.0.0.1:27019/flodb?authSource=flodb
# Optional documentation — not consumed at runtime, just a reminder for ops:
# CS_DB_TUNNEL_COMMAND="ssh -N -L 27018:127.0.0.1:27017 <user>@<crmdb-host>"
# CS_FLO_DB_TUNNEL_COMMAND="ssh -N -L 27019:127.0.0.1:27017 <user>@<flodb-host>"

# ── ETL alerts ────────────────────────────────────────────────────────────────
ALERT_EMAIL=alerts@example.com
ALERT_FROM=NOBL Dashboard <alerts@example.com>
# RESEND_API_KEY=re_xxxxxxxxxx
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
