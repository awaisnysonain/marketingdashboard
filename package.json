{
  "name": "nobl-air-dashboard",
  "version": "1.0.0",
  "description": "NOBL Air & Pilates FLO executive dashboard — PostgreSQL analytics with React frontend",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
