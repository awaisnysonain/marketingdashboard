    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.17.3",
    "googleapis": "^140.0.0",
    "helmet": "^7.1.0",
    "mongodb": "^7.4.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "openai": "^6.34.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
